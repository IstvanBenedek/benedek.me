{
  "name": "benedek-me",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:security": "node scripts/prebuild-checks.mjs",
    "build:app": "node scripts/prebuild-checks.mjs && vite build && vite build --ssr src/entry-server.js --outDir ../.svelte-dist-ssr && node scripts/prerender.mjs",
    "build": "npm run build:app && node scripts/publish-root.mjs",
    "preview": "vite preview",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.7",
    "vite": "^7.3.1"
  }
}
